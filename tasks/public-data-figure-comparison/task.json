{
  "schema_version": 1,
  "task_id": "yanglabkit-public-data-figures-v1",
  "task_version": "1.1.0",
  "snapshot_date": "2026-07-13",
  "output": {
    "format": "png"
  },
  "figures": [
    {
      "id": "gistemp-zonal-lines",
      "type": "line",
      "input": "data/gistemp-zonal-rolling.csv",
      "output": "gistemp-zonal-lines.png",
      "x": "year",
      "series": [
        "northern_extratropics_anomaly_c",
        "tropics_anomaly_c",
        "southern_extratropics_anomaly_c"
      ]
    },
    {
      "id": "world-bank-urbanization-bars",
      "type": "horizontal-bar",
      "input": "data/world-bank-urbanization-2024.csv",
      "output": "world-bank-urbanization-bars.png",
      "category": "region",
      "value": "urban_population_percent"
    },
    {
      "id": "palmer-penguins-box",
      "type": "box",
      "input": "data/palmer-penguins-body-mass.csv",
      "output": "palmer-penguins-box.png",
      "category": "species",
      "value": "body_mass_g"
    },
    {
      "id": "wine-correlation-heatmap",
      "type": "heatmap",
      "input": "data/uci-red-wine-correlations.csv",
      "output": "wine-correlation-heatmap.png",
      "row_label": "variable"
    },
    {
      "id": "auto-mpg-scatter",
      "type": "scatter",
      "input": "data/uci-auto-mpg.csv",
      "output": "auto-mpg-scatter.png",
      "x": "weight_lb",
      "y": "mpg",
      "group": "origin"
    },
    {
      "id": "usgs-earthquake-histogram",
      "type": "histogram",
      "input": "data/usgs-2025-reviewed-m5.csv",
      "output": "usgs-earthquake-histogram.png",
      "value": "magnitude",
      "bin_start": 5.0,
      "bin_width": 0.1,
      "normalization": "percent_of_events"
    }
  ]
}
